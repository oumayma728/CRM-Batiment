@startuml
title Diagramme de classes global - CRM Batiment

top to bottom direction
hide circle
skinparam linetype ortho
skinparam shadowing false
skinparam packageStyle rectangle
skinparam classAttributeIconSize 0

skinparam package {
  BorderColor #4B5563
  BackgroundColor #F9FAFB
}

skinparam class {
  BorderColor #374151
  BackgroundColor white
  ArrowColor #374151
}

skinparam enum {
  BorderColor #6B7280
  BackgroundColor #F3F4F6
}

package "Administration & CRM" {
  class Company {
    +id: Int
    +nom: String
    +siret: String
    +tvaDefaut: Float
    +devise: String
    --
    +configurerTVA()
    +configurerDevise()
  }

  class User {
    +id: Int
    +companyId: Int
    +nom: String
    +prenom: String
    +email: String
    +role: Role
    +actif: Boolean
    --
    +createUser()
    +login()
    +changePassword()
    +saveSignature()
  }

  class TypeProjet {
    +id: Int
    +companyId: Int
    +nom: String
    +description: String
    +actif: Boolean
    --
    +create()
    +findAll()
    +update()
    +remove()
  }

  class Client {
    +id: Int
    +companyId: Int
    +nom: String
    +prenom: String
    +telephone: String
    +email: String
    +adresseClient: String
    +adresseChantier: String
    +source: LeadSource
    --
    +create()
    +findAll()
    +findOne()
    +update()
    +remove()
  }

  class ClientTypeProjet {
    +clientId: Int
    +typeProjetId: Int
    +createdAt: DateTime
  }

  class DemandeDevis {
    +id: Int
    +companyId: Int
    +clientId: Int
    +createurId: Int
    +date: DateTime
    +description: String
    +statut: DemandeStatut
    --
    +create()
    +findAll()
    +findOne()
    +update()
    +updateStatut()
    +remove()
  }
}

package "Catalogue & Chiffrage" {
  class CategoriePrestation {
    +id: Int
    +companyId: Int
    +nom: String
    +description: String
    +actif: Boolean
    --
    +createCategorie()
    +findAllCategories()
    +updateCategorie()
    +deleteCategorie()
  }

  class SousCategorie {
    +id: Int
    +categorieId: Int
    +nom: String
    +description: String
    +actif: Boolean
    --
    +createSousCategorie()
    +findAllSousCategories()
    +updateSousCategorie()
    +deleteSousCategorie()
  }

  class TypeProjetCategorie {
    +typeProjetId: Int
    +categorieId: Int
    +ordre: Int
    +createdAt: DateTime
  }

  class Prestation {
    +id: Int
    +companyId: Int
    +categorieId: Int
    +sousCategorieId: Int
    +nom: String
    +unite: Unite
    +prixVenteMin: Float
    +prixVenteMax: Float
    +actif: Boolean
    --
    +createPrestation()
    +findAllPrestations()
    +findOnePrestation()
    +updatePrestation()
    +deletePrestation()
    +chiffrage()
  }

  class OptionPrestation {
    +id: Int
    +prestationId: Int
    +nom: String
    +obligatoire: Boolean
    +ordre: Int
    --
    +createOptionPrestation()
    +findOptionsByPrestation()
    +updateOptionPrestation()
    +deleteOptionPrestation()
  }

  class ChoixOption {
    +id: Int
    +optionId: Int
    +nom: String
    +impactPrix: Float
    +actif: Boolean
    +ordre: Int
    --
    +addChoixToOption()
    +updateChoixOption()
    +deleteChoixOption()
  }

  class PrestationComposition {
    +id: Int
    +prestationId: Int
    +materiauId: Int
    +serviceMainOeuvreId: Int
    +quantiteParUnite: Float
    --
    +createPrestationComposition()
    +updatePrestationComposition()
    +deletePrestationComposition()
  }

  class ChoixOptionComposition {
    +id: Int
    +choixOptionId: Int
    +materiauId: Int
    +serviceMainOeuvreId: Int
    +quantiteParUnite: Float
  }

  class Materiau {
    +id: Int
    +companyId: Int
    +nom: String
    +unite: Unite
    +prixAchatFixe: Float
    +fournisseurId: Int
    +actif: Boolean
    --
    +create()
    +findAll()
    +findOne()
    +update()
    +delete()
  }

  class ServiceMainOeuvre {
    +id: Int
    +companyId: Int
    +nom: String
    +unite: Unite
    +prixUnitaire: Float
    +productiviteJour: Float
    +actif: Boolean
    --
    +create()
    +findAll()
    +findOne()
    +update()
    +delete()
  }
}

package "Vente & Facturation" {
  class Devis {
    +id: Int
    +companyId: Int
    +clientId: Int
    +chantierId: Int
    +demandeDevisId: Int
    +reference: String
    +statut: DevisStatut
    +versionCourante: Int
    +totalHT: Float
    +totalTTC: Float
    +tauxTVA: Float
    --
    +create()
    +findAll()
    +findOne()
    +update()
    +updateStatut()
    +sendToClient()
    +addLigne()
    +updateLigne()
    +removeLigne()
  }

  class LigneDevis {
    +id: Int
    +devisId: Int
    +prestationId: Int
    +materiauId: Int
    +serviceMainOeuvreId: Int
    +quantite: Float
    +unite: Unite
    +prixUnitaireVente: Float
    +prixAchat: Float
    +mainOeuvre: Float
    +totalHT: Float
  }

  class DevisClientSignatureRequest {
    +id: Int
    +devisId: Int
    +token: String
    +telephoneClient: String
    +statut: DevisClientSignatureStatut
    +expiresAt: DateTime
    --
    +sendClientSignatureRequest()
    +sendPublicSignatureOtp()
    +verifyPublicSignatureOtp()
    +submitPublicClientSignature()
  }

  class VersionDevis {
    +id: Int
    +devisId: Int
    +auteurId: Int
    +numeroVersion: Int
    +justification: String
    +snapshotLignes: Json
    +totalHT: Float
    +totalTTC: Float
  }

  class Facture {
    +id: Int
    +devisId: Int
    +reference: String
    +date: DateTime
    +montantHT: Float
    +montantTTC: Float
    +statut: FactureStatut
    +typeFacture: FactureType
    --
    +createFromDevis()
    +findAll()
    +findOne()
    +update()
    +addLigne()
    +updateLigne()
    +removeLigne()
    +updateStatut()
    +sendToClient()
  }

  class FactureLigne {
    +id: Int
    +factureId: Int
    +description: String
    +quantite: Float
    +prixUnitaireHT: Float
    +montantHT: Float
    +montantTVA: Float
    +montantTTC: Float
  }

  class BonCommande {
    +id: Int
    +devisId: Int
    +reference: String
    +date: DateTime
    +statut: BonCommandeStatut
    --
    +validateBonCommandeAndSend()
  }
}

package "Approvisionnement" {
  class Fournisseur {
    +id: Int
    +companyId: Int
    +nom: String
    +contact: String
    +email: String
    +telephone: String
    +delaiLivraison: Int
    +actif: Boolean
    --
    +create()
    +findAll()
    +findOne()
    +update()
    +delete()
  }

  class CommandeFournisseur {
    +id: Int
    +devisId: Int
    +fournisseurId: Int
    +reference: String
    +date: DateTime
    +statutLivraison: CommandeFournisseurStatut
    +dateLivraisonPrevue: DateTime
    --
    +findAll()
    +findOne()
    +update()
    +send()
    +createReception()
  }

  class LigneCommandeFournisseur {
    +id: Int
    +commandeFournisseurId: Int
    +materiauNom: String
    +quantite: Float
    +prixUnitaire: Float
    +totalHT: Float
  }

  class Reception {
    +id: Int
    +commandeFournisseurId: Int
    +dateReception: DateTime
    +quantiteRecue: Float
    +quantiteAttendue: Float
    +partielle: Boolean
  }
}

package "Chantier & Execution" {
  class Chantier {
    +id: Int
    +companyId: Int
    +clientId: Int
    +chefChantierId: Int
    +reference: String
    +adresse: String
    +statut: ChantierStatut
    +dateDebut: DateTime
    +dateFin: DateTime
    --
    +syncFromAcceptedDevis()
    +findAll()
    +findOne()
    +create()
    +update()
    +listTasks()
  }

  class Tache {
    +id: Int
    +chantierId: Int
    +libelle: String
    +statut: TacheStatut
    +dateDebut: DateTime
    +dateFin: DateTime
    +avancement: Float
    +ordre: Int
    --
    +createTask()
    +updateTask()
    +removeTask()
  }

  class AffectationTache {
    +id: Int
    +tacheId: Int
    +userId: Int
    +equipeId: Int
    +createdAt: DateTime
  }

  class Equipe {
    +id: Int
    +companyId: Int
    +nom: String
    +type: EquipeType
    +actif: Boolean
  }

  class DocumentChantier {
    +id: Int
    +chantierId: Int
    +nom: String
    +type: String
    +url: String
  }
}

package "Assistant & Traceabilite" {
  class ChatSession {
    +id: Int
    +companyId: Int
    +clientNom: String
    +clientEmail: String
    +clientTelephone: String
    +terminee: Boolean
    --
    +createSession()
    +closeSession()
  }

  class MessageChat {
    +id: Int
    +sessionId: Int
    +userId: Int
    +role: String
    +contenu: String
    +createdAt: DateTime
    --
    +addMessage()
  }

  class AuditLog {
    +id: Int
    +companyId: Int
    +userId: Int
    +action: String
    +entite: String
    +entiteId: Int
    +createdAt: DateTime
    --
    +tracerAction()
  }
}

enum Role {
  ADMIN
  TECHNICO
  ASSISTANTE
  CHEF_CHANTIER
  SOUS_TRAITANT
}

enum LeadSource {
  CHATBOT
  TECHNICO_COMMERCIAL
  APPEL
  RECOMMANDATION
  SITE_WEB
  AUTRE
}

enum DemandeStatut {
  NOUVEAU
  EN_COURS
  QUALIFIE
  CONVERTI
  PERDU
}

enum DevisStatut {
  BROUILLON
  ENVOYE
  ACCEPTE
  SIGNE
  REFUSE
  ANNULE
  REVISE
  RENVOYE
}

enum DevisClientSignatureStatut {
  EN_ATTENTE
  OTP_ENVOYE
  OTP_VERIFIE
  SIGNE_CLIENT
  BLOQUE
  EXPIRE
  ANNULE
}

enum FactureStatut {
  BROUILLON
  ENVOYEE
  PAYEE
  ANNULEE
}

enum FactureType {
  ACOMPTE
  FINALE
}

enum BonCommandeStatut {
  BROUILLON
  VALIDE
  ENVOYE
  ANNULE
}

enum CommandeFournisseurStatut {
  CREEE
  ENVOYEE
  EXPEDIEE
  PARTIELLE
  RECUE
  CLOTUREE
}

enum ChantierStatut {
  VISITE_TECHNIQUE
  DEVIS_EN_PREPARATION
  DEVIS_ENVOYE
  NEGOCIATION_EN_COURS
  DEVIS_VALIDE
  COMMANDES_GENEREES
  MATERIAUX_EN_LIVRAISON
  MATERIAUX_RECEPTIONNES
  PLANIFIE
  DEMARRE
  EN_COURS
  TERMINE
  CLOTURE
}

enum TacheStatut {
  A_FAIRE
  EN_COURS
  BLOQUEE
  TERMINEE
}

enum EquipeType {
  INTERNE
  SOUS_TRAITANT
}

enum Unite {
  M2
  ML
  PIECE
  JOUR
  HEURE
  LITRE
  KG
  FORFAIT
}

Company "1" -- "0..*" User
Company "1" -- "0..*" Client
Company "1" -- "0..*" TypeProjet
Company "1" -- "0..*" DemandeDevis
Company "1" -- "0..*" CategoriePrestation
Company "1" -- "0..*" Prestation
Company "1" -- "0..*" Materiau
Company "1" -- "0..*" ServiceMainOeuvre
Company "1" -- "0..*" Fournisseur
Company "1" -- "0..*" Devis
Company "1" -- "0..*" Chantier
Company "1" -- "0..*" Equipe
Company "1" -- "0..*" ChatSession
Company "1" -- "0..*" AuditLog

User "0..1" -- "0..*" DemandeDevis : createur
User "0..1" -- "0..*" Devis : createur
User "0..1" -- "0..*" VersionDevis : auteur
User "0..1" -- "0..*" Chantier : chefChantier
User "0..1" -- "0..*" MessageChat : auteur
User "0..1" -- "0..*" AuditLog : acteur
User "0..1" -- "0..*" AffectationTache : sousTraitant

Client "1" -- "0..*" DemandeDevis
Client "1" -- "0..*" Devis
Client "1" -- "0..*" Chantier
Client "0..*" --> "0..1" TypeProjet : type principal
Client "0..*" -- "0..*" TypeProjet : types secondaires
(Client, TypeProjet) .. ClientTypeProjet

TypeProjet "0..*" -- "0..*" CategoriePrestation : categories autorisees
(TypeProjet, CategoriePrestation) .. TypeProjetCategorie

CategoriePrestation "1" -- "0..*" SousCategorie
CategoriePrestation "1" -- "0..*" Prestation
SousCategorie "0..1" -- "0..*" Prestation

Prestation "1" -- "0..*" OptionPrestation
OptionPrestation "1" -- "1..*" ChoixOption
Prestation "1" -- "0..*" PrestationComposition
ChoixOption "1" -- "0..*" ChoixOptionComposition

Materiau "0..1" -- "0..*" PrestationComposition
ServiceMainOeuvre "0..1" -- "0..*" PrestationComposition
Materiau "0..1" -- "0..*" ChoixOptionComposition
ServiceMainOeuvre "0..1" -- "0..*" ChoixOptionComposition
Fournisseur "0..1" -- "0..*" Materiau

DemandeDevis "0..1" -- "0..*" Devis : source
Chantier "0..1" -- "0..*" Devis
Devis "1" *-- "1..*" LigneDevis
LigneDevis "0..*" --> "0..1" Prestation
LigneDevis "0..*" --> "0..1" Materiau
LigneDevis "0..*" --> "0..1" ServiceMainOeuvre
Devis "1" -- "0..*" DevisClientSignatureRequest
Devis "1" -- "0..*" VersionDevis
Devis "1" -- "0..*" Facture
Devis "1" -- "0..1" BonCommande

Facture "1" *-- "1..*" FactureLigne

Devis "1" -- "0..*" CommandeFournisseur
Fournisseur "1" -- "0..*" CommandeFournisseur
CommandeFournisseur "1" *-- "1..*" LigneCommandeFournisseur
CommandeFournisseur "1" -- "0..*" Reception

Chantier "1" -- "0..*" Tache
Tache "1" -- "0..*" AffectationTache
Equipe "0..1" -- "0..*" AffectationTache : equipe interne
Chantier "1" -- "0..*" DocumentChantier

ChatSession "1" -- "0..*" MessageChat

legend left
  *--  composition forte
  --   association
  ..   classe d'association
endlegend

@enduml
